# Configuration Unsplash API - TEMPLATE
# 
# Copier ce fichier en .env et remplir vos clés API :
#   cp .env.example .env
#
# Obtenir vos clés sur : https://unsplash.com/oauth/applications
# 1. Allez sur https://unsplash.com/oauth/applications
# 2. Créez une nouvelle application
# 3. Copiez votre "Access Key" ci-dessous

# Clé d'accès Unsplash API
UNSPLASH_ACCESS_KEY=votre_access_key_ici

# Clé secrète Unsplash API (optionnel pour recherche basique)
UNSPLASH_SECRET_KEY=votre_secret_key_ici
